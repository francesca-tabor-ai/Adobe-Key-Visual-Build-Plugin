{
  "id": "com.kvbuildengine.plugin",
  "name": "KV Build Engine",
  "version": "1.0.0",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "22.0.0"
    }
  ],
  "manifestVersion": 4,
  "entrypoints": [
    {
      "type": "panel",
      "id": "kvBuildEnginePanel",
      "label": {
        "default": "KV Build Engine"
      },
      "minimumSize": {
        "width": 250,
        "height": 400
      },
      "maximumSize": {
        "width": 500,
        "height": 800
      },
      "preferredSize": {
        "width": 300,
        "height": 600
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "all",
    "network": {
      "domains": "all"
    },
    "launchProcess": "all"
  },
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "icons/icon-24.png",
      "scale": [1, 2],
      "theme": ["darker", "dark", "medium", "light"]
    }
  ]
}
